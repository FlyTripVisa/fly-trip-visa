  {
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "WORKER-NAME",
    "main": "src/index.ts",
    "compatibility_date": "2025-02-04",
    "compatibility_flags": [
      "nodejs_compat"
    ],
    "observability": {
      "enabled": true
    },
    "hyperdrive": [
      {
        "binding": "HYPERDRIVE",
        "id": "<YOUR_HYPERDRIVE_ID>",
        "localConnectionString": "<ENTER_LOCAL_CONNECTION_STRING_FOR_LOCAL_DEVELOPMENT_HERE>"
      }
    ]
  }